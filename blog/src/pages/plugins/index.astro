---
import BaseLayout from '@layouts/BaseLayout.astro';
import TagBadge from '@components/TagBadge.astro';
import { getCollection } from 'astro:content';

const plugins = await getCollection('plugins');

const CATEGORY_ORDER = [
  'Interview & Planning',
  'Career & Market',
  'Portfolio & Finance',
  'Content & Learning',
  'Analysis & Meta',
  'Other',
];

// Pre-build sections in frontmatter — avoids nested map + ternary issues in Astro JSX
const sections = CATEGORY_ORDER
  .map((cat) => ({
    label: cat,
    items: plugins
      .filter((p) => p.data.category === cat)
      .sort((a, b) => a.data.title.localeCompare(b.data.title)),
  }))
  .filter((s) => s.items.length > 0);

const totalAgents = plugins.reduce((sum, p) => sum + (p.data.agentCount ?? 0), 0);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Plugins" description="Claude Code plugins built for AI engineering workflows">
  <div class="portfolio-intro">
    <h1>Plugins</h1>
    <p class="intro-desc">
      {plugins.length} Claude Code plugins — each an independent AI pipeline built for real workflows.
      Covers career analysis, market research, portfolio management, content generation, and meta-tooling.
      Combined: <strong>{totalAgents}+ agent invocations</strong> across all pipelines.
    </p>
    <div class="intro-stats">
      {sections.map((s) => (
        <span class="stat-chip">
          <span class="stat-count">{s.items.length}</span>
          {s.label}
        </span>
      ))}
    </div>
  </div>

  {plugins.length === 0 && (
    <p class="empty">Run <code>npm run sync-plugins</code> to sync plugin docs.</p>
  )}

  {sections.map((section) => (
    <section class="category-section">
      <h2 class="category-title">{section.label}</h2>
      <div class="plugin-grid">
        {section.items.map((plugin) => (
          <div class="plugin-card">
            <a href={`${base}plugins/${plugin.slug}/`} class="card-overlay" aria-label={plugin.data.title}></a>
            <div class="card-header">
              <span class="plugin-name">{plugin.data.title}</span>
              {plugin.data.agentCount != null && (
                <span class="agent-badge">{plugin.data.agentCount} agents</span>
              )}
            </div>
            {plugin.data.description != null && (
              <p class="plugin-desc">{plugin.data.description}</p>
            )}
            {plugin.data.tags.length > 0 && (
              <div class="plugin-tags">
                {plugin.data.tags.slice(0, 3).map((tag) => (
                  <TagBadge tag={tag} />
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .portfolio-intro {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }

  .intro-desc {
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    line-height: 1.6;
    max-width: 680px;
  }

  .intro-desc strong {
    color: var(--color-text);
  }

  .intro-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stat-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    padding: 0.25rem 0.65rem;
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text-muted);
  }

  .stat-count {
    font-weight: 700;
    color: var(--color-primary);
  }

  .category-section {
    margin-bottom: 2.5rem;
  }

  .category-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .plugin-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .plugin-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: inherit;
    transition: border-color 0.2s, background 0.2s;
  }

  .plugin-card:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-muted);
  }

  /* Whole-card clickable overlay — sits below tag links */
  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 8px;
  }

  /* Tag links must sit above the overlay */
  .plugin-tags {
    position: relative;
    z-index: 1;
  }

  .card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .plugin-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .agent-badge {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    border-radius: 10px;
    white-space: nowrap;
  }

  .plugin-desc {
    font-size: 0.83rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    flex: 1;
  }

  .plugin-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .empty {
    color: var(--color-text-muted);
    text-align: center;
    padding: 3rem 0;
  }

  @media (max-width: 640px) {
    .plugin-grid {
      grid-template-columns: 1fr;
    }

    .intro-stats {
      gap: 0.35rem;
    }
  }
</style>
